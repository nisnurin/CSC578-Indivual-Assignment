/* Navigation fixed at top */
#navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: #333;
    display: flex;
    padding: 1rem;
    gap: 20px;
}

#navbar a { color: white; text-decoration: none; }

/* Welcome Section: Full Viewport Height */
#welcome-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: #f4f4f4;
}

/* Projects Section */
#project-section {
    padding: 2rem;
    text-align: center;
}

.project-tile {
    border: 1px solid #ddd;
    padding: 20px;
    margin: 10px;
}

/* Responsive design */
@media (max-width: 600px) {
    #navbar { flex-direction: column; align-items: center; }
}
